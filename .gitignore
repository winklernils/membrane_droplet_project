# This defines all the files and directories that should be ignored by Git 
# in the membrane droplet project. It includes common patterns for Python projects, 
# virtual environments, Jupyter notebooks, macOS system files, data and results directories, 
# figures, large numerical files, logs, and temporary files.

# Python
__pycache__/
*.pyc

# Virtual environments
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# Data & results
data/
results/

# Figures
figures/

# Large numerical files
*.npy
*.npz
*.h5

# Logs
*.log

# Temporary files
tmp/